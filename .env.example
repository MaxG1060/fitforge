# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# Supabase (database + auth) - get from supabase.com > project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Claude API (AI training plans + meal prep) - get from console.anthropic.com
# Note: do NOT name this ANTHROPIC_API_KEY - Next.js 16 / Turbopack strips that name
CLAUDE_API_KEY=

# Strava API (activity sync) - get from strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
